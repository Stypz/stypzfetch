#!/usr/bin/env bash

# Colors
RESET='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
MAGENTA='\033[0;35m'
RED='\033[0;31m'
WHITE='\033[0;37m'
BRIGHT_RED='\033[1;31m'
BRIGHT_GREEN='\033[1;32m'
BRIGHT_YELLOW='\033[1;33m'

# ─── ASCII Art Logo ───────────────────────────────────────────────────────────
print_logo() {
    echo -e "${CYAN}${BOLD}"
    cat << "EOF"
   _____ __                   ______     __       __  
  / ___// /___  ______  ____/ ____/__  / /______/ /_ 
  \__ \/ __/ / / / __ \/_  / /_  / _ \/ __/ ___/ __ \
 ___/ / /_/ /_/ / /_/ / / / __/ /  __/ /_/ /__/ / / /
/____/\__/\__, / .___/ /_/_/    \___/\__/\___/_/ /_/ 
         /____/_/                                     
EOF
    echo -e "${RESET}"
}

# ─── Progress Bar ─────────────────────────────────────────────────────────────
# Usage: make_bar <percentage_int> [bar_width]
# Prints a filled/empty bar with color based on usage level
make_bar() {
    local pct="$1"
    local width="${2:-20}"

    # Clamp to 0–100
    [ "$pct" -lt 0 ]   2>/dev/null && pct=0
    [ "$pct" -gt 100 ] 2>/dev/null && pct=100

    local filled=$(( pct * width / 100 ))
    local empty=$(( width - filled ))

    # Color by threshold
    local bar_color
    if   [ "$pct" -ge 85 ]; then bar_color="$RED"
    elif [ "$pct" -ge 60 ]; then bar_color="$YELLOW"
    else                          bar_color="$GREEN"
    fi

    printf "${bar_color}${BOLD}["
    printf '%0.s█' $(seq 1 $filled)
    printf "${DIM}${WHITE}"
    [ $empty -gt 0 ] && printf '%0.s░' $(seq 1 $empty)
    printf "${bar_color}${BOLD}]${RESET}"
}

# ─── System Information Getters ───────────────────────────────────────────────

get_os() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        echo "${PRETTY_NAME:-$NAME $VERSION}"
    elif [ -f /etc/lsb-release ]; then
        . /etc/lsb-release
        echo "$DISTRIB_DESCRIPTION"
    else
        uname -s
    fi
}

get_kernel() {
    uname -r
}

get_uptime() {
    if [ -f /proc/uptime ]; then
        local secs
        secs=$(cut -d. -f1 /proc/uptime)
        local d=$(( secs / 86400 ))
        local h=$(( (secs % 86400) / 3600 ))
        local m=$(( (secs % 3600) / 60 ))
        local s=$(( secs % 60 ))

        local str=""
        [ $d -gt 0 ] && str="${d}d "
        [ $h -gt 0 ] && str="${str}${h}h "
        [ $m -gt 0 ] && str="${str}${m}m "
        # Only show seconds when uptime < 1 minute
        [ -z "$str" ] && str="${s}s"
        echo "${str% }"    # trim trailing space
    else
        uptime | awk '{print $3}' | sed 's/,//'
    fi
}

get_packages() {
    if command -v dpkg &>/dev/null; then
        echo "$(dpkg -l | grep -c ^ii) (dpkg)"
    elif command -v rpm &>/dev/null; then
        echo "$(rpm -qa | wc -l) (rpm)"
    elif command -v pacman &>/dev/null; then
        echo "$(pacman -Q | wc -l) (pacman)"
    else
        echo "Unknown"
    fi
}

get_shell() {
    # Show just the shell name + version, not the full path
    local name
    name=$(basename "${SHELL:-sh}")
    local ver=""
    case "$name" in
        bash)   ver=$("$SHELL" --version 2>/dev/null | head -1 | grep -o '[0-9]*\.[0-9]*\.[0-9]*' | head -1) ;;
        zsh)    ver=$("$SHELL" --version 2>/dev/null | awk '{print $2}') ;;
        fish)   ver=$("$SHELL" --version 2>/dev/null | awk '{print $3}') ;;
    esac
    [ -n "$ver" ] && echo "$name $ver" || echo "$name"
}

get_cpu() {
    if [ -f /proc/cpuinfo ]; then
        local cpu
        cpu=$(grep "model name" /proc/cpuinfo | head -n1 | cut -d: -f2 \
              | sed 's/^[ \t]*//' | sed 's/(R)//g' | sed 's/(TM)//g' \
              | sed 's/  */ /g' | sed 's/[ \t]*$//')

        if [ -z "$cpu" ] || [ "$cpu" = "unknown" ]; then
            local vendor family model
            vendor=$(grep "vendor_id"       /proc/cpuinfo | head -n1 | cut -d: -f2 | sed 's/^[ \t]*//')
            family=$(grep "cpu family"      /proc/cpuinfo | head -n1 | cut -d: -f2 | sed 's/^[ \t]*//')
            model=$(grep  "^model[[:space:]]" /proc/cpuinfo | head -n1 | cut -d: -f2 | sed 's/^[ \t]*//')
            [ -n "$vendor" ] && cpu="$vendor" \
                && [ -n "$family" ] && [ -n "$model" ] \
                && cpu="$cpu Family $family Model $model"
            # ARM fallback
            [ -z "$cpu" ] && cpu=$(grep -m1 "Hardware" /proc/cpuinfo | cut -d: -f2 | sed 's/^[ \t]*//')
        fi

        [ -z "$cpu" ] && cpu="Unknown CPU"

        local cores
        cores=$(grep -c "^processor" /proc/cpuinfo)

        # Try to get max frequency
        local freq=""
        if [ -f /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq ]; then
            local hz
            hz=$(cat /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq 2>/dev/null)
            if [ -n "$hz" ]; then
                local ghz
                ghz=$(awk "BEGIN {printf \"%.1f\", $hz / 1000000}")
                freq=" @ ${ghz} GHz"
            fi
        fi

        echo "$cpu ($cores cores${freq})"
    else
        uname -p
    fi
}

# Returns "usage_int pct_string bar" — separated by tab for the caller
get_cpu_usage() {
    if [ -f /proc/stat ]; then
        read_cpu() {
            grep "^cpu " /proc/stat | awk '{idle=$5; total=$2+$3+$4+$5+$6+$7+$8; print idle " " total}'
        }
        local r1; r1=$(read_cpu)
        sleep 0.3
        local r2; r2=$(read_cpu)

        local idle1 total1 idle2 total2
        idle1=$(echo "$r1" | awk '{print $1}'); total1=$(echo "$r1" | awk '{print $2}')
        idle2=$(echo "$r2" | awk '{print $1}'); total2=$(echo "$r2" | awk '{print $2}')

        local d_idle=$(( idle2  - idle1  ))
        local d_total=$(( total2 - total1 ))

        local pct=0
        [ "$d_total" -gt 0 ] && pct=$(( (d_total - d_idle) * 100 / d_total ))

        printf "%d\t%d%%\t" "$pct" "$pct"
        make_bar "$pct"
    else
        printf "0\tN/A\t"
    fi
}

get_memory() {
    if [ -f /proc/meminfo ]; then
        local total avail used pct
        total=$(grep MemTotal     /proc/meminfo | awk '{print $2}')
        avail=$(grep MemAvailable /proc/meminfo | awk '{print $2}')
        used=$(( total - avail ))

        local used_mb=$(( used  / 1024 ))
        local total_mb=$(( total / 1024 ))

        pct=0
        [ "$total" -gt 0 ] && pct=$(( used * 100 / total ))

        # Format in GiB if >= 1024 MB
        local used_str total_str
        if [ "$total_mb" -ge 1024 ]; then
            used_str=$(awk "BEGIN {printf \"%.1f GiB\", $used_mb/1024}")
            total_str=$(awk "BEGIN {printf \"%.1f GiB\", $total_mb/1024}")
        else
            used_str="${used_mb} MiB"
            total_str="${total_mb} MiB"
        fi

        printf "%d\t%s / %s (%d%%)\t" "$pct" "$used_str" "$total_str" "$pct"
        make_bar "$pct"
    else
        printf "0\tUnknown\t"
    fi
}

get_disk() {
    local pct_raw line
    line=$(df -h / | awk 'NR==2')
    local used total pct_str
    used=$(echo "$line"    | awk '{print $3}')
    total=$(echo "$line"   | awk '{print $2}')
    pct_str=$(echo "$line" | awk '{print $5}')
    local pct="${pct_str%\%}"    # strip trailing %

    printf "%d\t%s / %s (%s)\t" "$pct" "$used" "$total" "$pct_str"
    make_bar "$pct"
}

get_gpu() {
    local gpu=""
    # Try lspci first
    if command -v lspci &>/dev/null; then
        gpu=$(lspci 2>/dev/null | grep -i "vga\|3d\|display" | head -n1 \
              | sed 's/.*: //' | sed 's/ (rev [0-9a-f]*)$//')
    fi
    # Fallback: /sys
    if [ -z "$gpu" ] && [ -d /sys/class/drm ]; then
        gpu=$(find /sys/class/drm/*/device/vendor 2>/dev/null | head -1 | xargs cat 2>/dev/null)
        [ -n "$gpu" ] && gpu="GPU vendor $gpu"
    fi
    echo "${gpu:-Not detected}"
}

get_network() {
    # Active interface: first non-loopback with an IPv4 address
    local iface ip
    if command -v ip &>/dev/null; then
        iface=$(ip -o -4 route show default 2>/dev/null | awk '{print $5}' | head -1)
        [ -z "$iface" ] && iface=$(ip -o -4 addr show 2>/dev/null \
            | grep -v ' lo ' | awk '{print $2}' | head -1)
        ip=$(ip -o -4 addr show "$iface" 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -1)
    elif command -v ifconfig &>/dev/null; then
        iface=$(ifconfig 2>/dev/null | grep -v "^lo" | grep "^[a-z]" | awk -F: '{print $1}' | head -1)
        ip=$(ifconfig "$iface" 2>/dev/null | grep "inet " | awk '{print $2}' | sed 's/addr://')
    fi
    [ -n "$iface" ] && [ -n "$ip" ] && echo "${iface}: ${ip}" \
        || echo "Not connected"
}

get_hostname() {
    echo "$(whoami)@$(hostname)"
}

get_terminal() {
    echo "${TERM:-Unknown}"
}

get_de_wm() {
    if   [ -n "$XDG_CURRENT_DESKTOP" ]; then echo "$XDG_CURRENT_DESKTOP"
    elif [ -n "$DESKTOP_SESSION"      ]; then echo "$DESKTOP_SESSION"
    else                                       echo "TTY"
    fi
}

get_virtualization() {
    local virt="Bare Metal"
    if   [ -f /.dockerenv ] || grep -q docker /proc/1/cgroup 2>/dev/null; then
        virt="Docker"
    elif grep -q lxc /proc/1/cgroup 2>/dev/null; then
        virt="LXC"
    elif command -v systemd-detect-virt &>/dev/null; then
        local d; d=$(systemd-detect-virt 2>/dev/null)
        [ "$d" != "none" ] && [ -n "$d" ] && virt="$d"
    elif grep -q "hypervisor" /proc/cpuinfo 2>/dev/null; then
        if   grep -qi "vmware"    /proc/cpuinfo /sys/class/dmi/id/* 2>/dev/null; then virt="VMware"
        elif grep -qi "virtualbox" /sys/class/dmi/id/*               2>/dev/null; then virt="VirtualBox"
        elif grep -qi "kvm"       /proc/cpuinfo /sys/class/dmi/id/* 2>/dev/null; then virt="KVM"
        elif grep -qi "qemu"      /proc/cpuinfo /sys/class/dmi/id/* 2>/dev/null; then virt="QEMU"
        elif grep -qi "xen"       /proc/cpuinfo /sys/class/dmi/id/* 2>/dev/null; then virt="Xen"
        else virt="Unknown VM"
        fi
    fi
    echo "$virt"
}

# ─── Rendering helpers ────────────────────────────────────────────────────────

print_info() {
    local label="$1"
    local value="$2"
    local color="${3:-$WHITE}"
    printf "${color}${BOLD}  %-13s${RESET}${DIM}│${RESET}  %b\n" "$label" "$value"
}

# For metrics that include a bar: value already has embedded escape codes
print_metric() {
    local label="$1"
    local text="$2"    # e.g. "3.2 GiB / 15.5 GiB (21%)"
    local bar="$3"     # output of make_bar (already colored)
    local color="${4:-$WHITE}"
    printf "${color}${BOLD}  %-13s${RESET}${DIM}│${RESET}  %-34b  %b\n" "$label" "$text" "$bar"
}

# ─── Main ─────────────────────────────────────────────────────────────────────

print_logo

local_host=$(get_hostname)
sep_len=$(( ${#local_host} + 4 ))
sep=$(printf '━%.0s' $(seq 1 40))

echo -e "  ${BOLD}${BRIGHT_GREEN}${local_host}${RESET}"
echo -e "  ${BLUE}${sep}${RESET}"
echo ""

print_info "OS"       "$(get_os)"            "$YELLOW"
print_info "Kernel"   "$(get_kernel)"        "$YELLOW"
print_info "Uptime"   "$(get_uptime)"        "$MAGENTA"
print_info "Packages" "$(get_packages)"      "$CYAN"
print_info "Shell"    "$(get_shell)"         "$GREEN"
print_info "DE / WM"  "$(get_de_wm)"        "$BLUE"
print_info "Terminal" "$(get_terminal)"      "$RED"
print_info "Virt"     "$(get_virtualization)" "$MAGENTA"
print_info "GPU"      "$(get_gpu)"           "$CYAN"
print_info "Network"  "$(get_network)"       "$GREEN"
print_info "CPU"      "$(get_cpu)"           "$CYAN"

echo ""
echo -e "  ${DIM}${BLUE}  Resources${RESET}"
echo -e "  ${BLUE}  ─────────────────────────────────────────${RESET}"

# CPU Usage
IFS=$'\t' read -r pct_int pct_str bar <<< "$(get_cpu_usage)"
print_metric "CPU Usage" "$pct_str" "$bar" "$CYAN"

# Memory
IFS=$'\t' read -r pct_int mem_str bar <<< "$(get_memory)"
print_metric "Memory" "$mem_str" "$bar" "$MAGENTA"

# Disk
IFS=$'\t' read -r pct_int disk_str bar <<< "$(get_disk)"
print_metric "Disk (/)" "$disk_str" "$bar" "$YELLOW"

echo ""
# Wider, richer color swatch
echo -ne "  "
for color in 1 2 3 4 5 6 7; do
    echo -ne "\033[4${color}m   \033[0m"
done
echo -ne "  "
for color in 1 2 3 4 5 6 7; do
    echo -ne "\033[10${color}m   \033[0m"
done
echo -e "\n"
